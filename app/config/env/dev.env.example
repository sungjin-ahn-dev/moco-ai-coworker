APP_ENV=dev

# Slack 연동
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_TEAM_ID=T00000000

# 봇 정보
BOT_NAME=MOCO
BOT_EMAIL=your-email@company.com
BOT_ORGANIZATION=Your Organization
BOT_TEAM=Your Team
BOT_AUTHORIZED_USERS_EN=Your Name
BOT_AUTHORIZED_USERS_KR=이름
BOT_ROLE=
FILESYSTEM_BASE_DIR=/Users/username/Documents/MOCO

# MCP 설정 - Perplexity
PERPLEXITY_ENABLED=False
PERPLEXITY_API_KEY=pplx-your-api-key

# MCP 설정 - DeepL
DEEPL_ENABLED=False
DEEPL_API_KEY=your-deepl-api-key

# MCP 설정 - GitHub
GITHUB_ENABLED=False
GITHUB_PERSONAL_ACCESS_TOKEN=

# MCP 설정 - GitLab
GITLAB_ENABLED=False
GITLAB_API_URL=https://gitlab.example.com
GITLAB_PERSONAL_ACCESS_TOKEN=glpat-your-token

# MCP 설정 - Microsoft 365 (Lokka)
MS365_ENABLED=False
MS365_CLIENT_ID=your-client-id
MS365_TENANT_ID=your-tenant-id

# MCP 설정 - Atlassian Rovo
ATLASSIAN_ENABLED=False
ATLASSIAN_CONFLUENCE_SITE_URL=https://your-site.atlassian.net
ATLASSIAN_CONFLUENCE_DEFAULT_PAGE_ID=000000000
ATLASSIAN_JIRA_SITE_URL=https://your-site.atlassian.net

# MCP 설정 - Google Drive
GOOGLE_DRIVE_ENABLED=False
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_DRIVE_OAUTH_CREDENTIALS=/path/to/client_secret.json

# MCP 설정 - CogSearch (Google Drive 시맨틱 검색)
COGSEARCH_ENABLED=False
COGSEARCH_API_KEY=your-cogsearch-api-key
COGSEARCH_BASE_URL=http://your-cogsearch-server:3050/api
COGSEARCH_PIPELINE=gdrive_pipeline

# MCP 설정 - Tableau
TABLEAU_ENABLED=False
TABLEAU_SERVER=https://your-tableau-server.com
TABLEAU_SITE_NAME=your-site
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_VALUE=your-pat-value

# MCP 설정 - X (Twitter)
X_ENABLED=False
X_API_KEY=your-api-key
X_API_SECRET=your-api-secret
X_ACCESS_TOKEN=your-access-token
X_ACCESS_TOKEN_SECRET=your-access-token-secret
X_OAUTH2_CLIENT_ID=your-oauth2-client-id
X_OAUTH2_CLIENT_SECRET=your-oauth2-client-secret

# MCP 설정 - Clova Speech
CLOVA_ENABLED=False
CLOVA_INVOKE_URL=https://clovaspeech-gw.ncloud.com/external/v1/your-url
CLOVA_SECRET_KEY=your-secret-key

# MCP 설정 - Custom Remote MCP
REMOTE_MCP_SERVERS=

# Computer Use
CHROME_ENABLED=False
CHROME_ALWAYS_PROFILE_SETUP=False

# 웹 서버 / 음성 수신 채널
WEB_INTERFACE_ENABLED=False
WEB_INTERFACE_AUTH_PROVIDER=microsoft
WEB_INTERFACE_URL=
# Cloudflare Quick Tunnel (TryCloudflare). True면 서버 기동 시 자동으로
# https://*.trycloudflare.com URL을 발급해 외부 접속을 열어준다.
# - Cloudflare 계정/도메인 불필요
# - 매 재시작마다 URL이 바뀜 → OAuth 콜백 재등록 필요
# - cloudflared 바이너리 설치 필요: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/
CLOUDFLARE_TUNNEL_ENABLED=True
WEB_SLACK_CLIENT_ID=your-slack-client-id
WEB_SLACK_CLIENT_SECRET=your-slack-client-secret
WEB_MS365_CLIENT_ID=
WEB_MS365_CLIENT_SECRET=
WEB_MS365_TENANT_ID=
WEB_GOOGLE_CLIENT_ID=
WEB_GOOGLE_CLIENT_SECRET=

# 능동 수신 채널 - Outlook
OUTLOOK_CHECK_ENABLED=False
OUTLOOK_CHECK_INTERVAL=5

# 능동 수신 채널 - Confluence
CONFLUENCE_CHECK_ENABLED=False
CONFLUENCE_CHECK_INTERVAL=60
CONFLUENCE_CHECK_HOURS=1

# 능동 수신 채널 - Jira
JIRA_CHECK_ENABLED=False
JIRA_CHECK_INTERVAL=30

# 선제적 제안 기능
DYNAMIC_SUGGESTER_ENABLED=False
DYNAMIC_SUGGESTER_INTERVAL=15

# Agent Factory (자동 에이전트 생성)
# AGENT_FACTORY_ENABLED=True              # 명시 요청("에이전트 만들어줘") 처리, 기본 True
# AGENT_APPROVER_SLACK_ID=                # 비우면 자동 publish, 채우면 Slack DM 승인 게이트
# AGENT_AUTO_ARCHIVE_DAYS=30              # 미사용 N일 후 archive
# Phase 2 — 자동 후보 감지 (일 1회 메모리 분석 → 사용자 confirm)
AGENT_CANDIDATE_SUGGESTER_ENABLED=True
AGENT_CANDIDATE_DETECT_WINDOW_DAYS=30
AGENT_LIFECYCLE_DAILY_HOUR=3

# Skill Marketplace
SKILL_MARKETPLACE_ENABLED=false
SKILL_MARKETPLACE_FOLDER_ID=
SKILL_AUTO_APPROVE=true

# MCP Server (외부 Claude Code/Desktop 노출)
MCP_ENABLED=False
MCP_PATH=/mcp
MCP_TOKEN_FILE=~/.moco/mcp_tokens.json
